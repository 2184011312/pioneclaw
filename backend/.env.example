# PioneClaw 环境配置（模板）
# 复制此文件为 .env 并填写真实值，.env 不会被 git 追踪
#
# 生成密钥 Linux/macOS: openssl rand -hex 32
# 生成密钥 Windows PowerShell:
#   -join ((48..57)+(97..102) | Get-Random -Count 64 | % {[char]$_})

# 应用配置
APP_NAME=PioneClaw
DEBUG=true
API_PREFIX=/api
VERSION=1.0.0

# 数据库配置
# SQLite (开发): sqlite+aiosqlite:///./pioneclaw.db
# PostgreSQL (生产): postgresql+asyncpg://user:pass@localhost:5432/pioneclaw
DATABASE_URL=sqlite+aiosqlite:///./pioneclaw.db

# JWT 配置（生产环境必须修改为 openssl rand -hex 32 生成的随机值）
SECRET_KEY=your-secret-key-change-in-production
REFRESH_SECRET_KEY=your-secret-key-change-in-production-please
RESET_SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# 密码重置
PASSWORD_RESET_EXPIRE_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# 外部 API Key (可选)
BRAVE_API_KEY=

# Redis 配置 (可选)
REDIS_URL=

# CORS 配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
