# PioneClaw Docker 部署环境变量（模板）
# 复制此文件为 .env 并填写真实值，.env 不会被 git 追踪
#
# 生成密钥: openssl rand -hex 32

# JWT 密钥
SECRET_KEY=change-me-run-openssl-rand-hex-32
REFRESH_SECRET_KEY=change-me-run-openssl-rand-hex-32

# PostgreSQL 数据库
DB_USER=pioneclaw
DB_PASSWORD=change-me
DB_NAME=pioneclaw

# 调试模式（生产环境设为 false）
DEBUG=false
